      "id": 5,
      "options": {
        "legend": {"calcs": [], "displayMode": "list", "placement": "bottom"},
        "tooltip": {"mode": "single"}
      },
      "targets": [
        {
          "expr": "rate(datacore_messages_produced_total[5m])",
          "legendFormat": "Produced/sec",
          "refId": "A"
        },
        {
          "expr": "rate(datacore_messages_consumed_total[5m])",
          "legendFormat": "Consumed/sec",
          "refId": "B"
        }
      ],
      "title": "Message Throughput",
      "type": "timeseries"
